# ROS Bridge WebSocket URL
# Default: ws://localhost:9090
# Change this if ROS runs on a different machine (e.g. Raspberry Pi 5)
#
# Examples:
#   NEXT_PUBLIC_ROS_URL=ws://localhost:9090       (ROS on same machine)
#   NEXT_PUBLIC_ROS_URL=ws://192.168.1.50:9090   (ROS on Pi5 in local network)
NEXT_PUBLIC_ROS_URL=ws://localhost:9090
