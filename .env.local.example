# ROS Bridge WebSocket URL
# Default: ws://localhost:9090
# Change this if ROS runs on a different machine (e.g. Raspberry Pi 5)
#
# Examples:
#   NEXT_PUBLIC_ROS_URL=ws://localhost:9090       (ROS on same machine)
#   NEXT_PUBLIC_ROS_URL=ws://192.168.1.50:9090   (ROS on Pi5 in local network)
NEXT_PUBLIC_ROS_URL=ws://localhost:9090

# Safety Camera Detector WebSocket (detector/main.py or mock_detector.py)
# Default: ws://localhost:8765
# Change to Jetson IP when deploying, e.g. ws://192.168.1.50:8765
NEXT_PUBLIC_SAFETY_WS_URL=ws://localhost:8765

# Wrist Camera WebSocket (wrist-cam/main.py or mock_wrist.py)
# Default: ws://localhost:8766
# Change to Jetson IP when deploying, e.g. ws://192.168.1.50:8766
NEXT_PUBLIC_WRIST_WS_URL=ws://localhost:8766
