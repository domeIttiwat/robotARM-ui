{
  "name": "robot-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "tsx prisma/seed.ts",
    "mock-ros": "tsx scripts/mock-ros.ts",
    "dev:full": "concurrently --names \"UI,ROS\" --prefix-colors \"blue,green\" \"next dev -p 3001\" \"tsx scripts/mock-ros.ts\"",
    "sim": "bash scripts/start-sim.sh",
    "sim:setup": "cd RobotArm_Project && python -m venv venv && venv/bin/pip install -r requirements.txt"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/adapter-better-sqlite3": "^7.4.1",
    "@prisma/client": "^6.19.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@types/three": "^0.183.1",
    "better-sqlite3": "^12.6.2",
    "lucide-react": "^0.376.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "roslib": "^2.0.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "ws": "^8.19.0"
  }
}
